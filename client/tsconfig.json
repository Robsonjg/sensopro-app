{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "baseUrl": ".",
    
    // Boa Prática: Silencia o aviso de depreciação exigido pelo TypeScript moderno
    "ignoreDeprecations": "6.0", 
    
    "types": ["vite/client"],
    "paths": {
      "@/*": ["src/*"],
      "@shared/*": ["../shared/*"],
      "@server/*": ["../server/*"],
      "@drizzle/*": ["../drizzle/*"]
    },
    "rootDir": "./src"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/vite-env.d.ts"
  ]
}