{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "..",
    "outDir": "./dist",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true
  },
  "include": [
    "./**/*.ts",
    "../drizzle/**/*.ts",
    "../shared/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}