{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "dist",

    "ignoreDeprecations": "5.0",
    "module": "ESNext",
    "moduleResolution": "Bundler"


  },

  "include": [
    "**/*.ts",
    "../shared/**/*.ts"
  ],
  "exclude": [
    "dist",
    "../client",
    "../node_modules"
  ]
}