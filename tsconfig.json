{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "skipLibCheck": true,

    "ignoreDeprecations": "6.0",

    "baseUrl": ".",

    "paths": {
      "@/*": ["client/src/*"],
      "@shared/*": ["shared/*"]
    },

    "types": ["vite/client"]
  }
}